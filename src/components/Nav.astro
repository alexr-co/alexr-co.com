---
import { site } from '../site.config';

const { pathname } = Astro.url;

const links = [
  { href: '/',         label: 'home' },
  { href: '/projects', label: 'projects' },
  { href: '/writing',  label: 'writing' },
  { href: '/journal',  label: 'journal' },
  { href: '/about',    label: 'about' },
  { href: '/resume',   label: 'resume' },
  { href: '/contact',  label: 'contact' },
];

const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname === href || pathname.startsWith(href + '/');
};
---

<header class="site-header">
  <div class="container header-row">
    <a href="/" class="brand">
      <span class="prompt">~</span><span class="muted">/{site.shortName}</span>
    </a>
    <nav aria-label="Primary">
      <input type="checkbox" id="nav-toggle" class="nav-checkbox" />
      <label for="nav-toggle" class="nav-trigger">
        <span class="prompt">$</span> menu
      </label>
      <ul class="nav-list">
        {links.slice(1).map((link) => (
          <li>
            <a
              href={link.href}
              class={isActive(link.href) ? 'nav-link active' : 'nav-link'}
              aria-current={isActive(link.href) ? 'page' : undefined}
            >
              {link.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    border-bottom: 1px solid var(--border-muted);
    background: var(--bg-primary);
    position: sticky;
    top: 0;
    z-index: 10;
    backdrop-filter: blur(8px);
  }

  .header-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-top: 0.9rem;
    padding-bottom: 0.9rem;
    gap: 1rem;
  }

  .brand {
    font-size: 0.85rem;
    color: var(--text-primary);
    border-bottom: none;
    white-space: nowrap;
  }

  .brand:hover {
    border-bottom: none;
  }

  /* Visually-hidden checkbox (still keyboard-accessible — tab to it, space to toggle) */
  .nav-checkbox {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Desktop default: hide the trigger label, show the nav list inline */
  .nav-trigger {
    display: none;
  }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    gap: 0.85rem;
    justify-content: flex-end;
  }

  .nav-link {
    color: var(--text-muted);
    font-size: 0.8rem;
    border-bottom: 1px solid transparent;
  }

  .nav-link:hover {
    color: var(--text-primary);
    border-bottom-color: transparent;
  }

  .nav-link.active {
    color: var(--text-primary);
    border-bottom: 1px solid var(--accent-link);
  }

  /* Mobile: one-row layout with brand left, trigger right; expanded list overlays below */
  @media (max-width: 540px) {
    .nav-trigger {
      display: block;
      cursor: pointer;
      color: var(--text-muted);
      font-size: 0.8rem;
      user-select: none;
    }

    .nav-trigger::after {
      content: ' ▾';
      color: var(--text-faint);
    }

    .nav-checkbox:checked ~ .nav-trigger::after {
      content: ' ▴';
    }

    .nav-trigger:hover {
      color: var(--text-primary);
    }

    /* Highlight the trigger when keyboard focus is on the hidden checkbox */
    .nav-checkbox:focus-visible ~ .nav-trigger {
      outline: 1px solid var(--accent-link);
      outline-offset: 2px;
    }

    /* Collapsed by default on mobile */
    .nav-list {
      display: none;
    }

    /* Expanded — absolutely positioned below the header so it overlays rather than pushing content */
    .nav-checkbox:checked ~ .nav-list {
      display: flex;
      flex-direction: column;
      align-items: flex-start;
      gap: 0.5rem;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      padding: 0.75rem var(--gutter);
      background: var(--bg-primary);
      border-bottom: 1px solid var(--border-muted);
    }
  }
</style>
