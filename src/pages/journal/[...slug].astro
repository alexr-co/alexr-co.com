---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('journal', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const dateFmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Base title={entry.data.title} description={`${entry.data.title} — journal entry`}>
  <article class="entry">
    <p class="back"><a href="/journal">&larr; back to journal</a></p>

    {entry.data.image && (
      <figure class="hero">
        <img src={entry.data.image} alt={entry.data.alt ?? entry.data.title} />
      </figure>
    )}

    <header class="entry-head">
      <p class="muted entry-meta">
        {dateFmt(entry.data.date)}
        {entry.data.location && <span class="faint"> &middot; {entry.data.location}</span>}
      </p>
      <h1>{entry.data.title}</h1>
    </header>

    <div class="entry-body">
      <Content />
    </div>
  </article>
</Base>

<style>
  .back { font-size: 0.8rem; margin: 0 0 1.5rem; }

  .hero {
    margin: 0 0 1.5rem;
    border: 1px solid var(--border-muted);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-secondary);
  }
  .hero img {
    width: 100%;
    height: auto;
    display: block;
  }

  .entry-head { margin-bottom: 1.5rem; }
  .entry-meta { font-size: 0.8rem; margin: 0 0 0.4rem; letter-spacing: 0.03em; }
  .entry h1 { margin: 0; font-size: 1.4rem; }

  .entry-body {
    max-width: 64ch;
    color: var(--text-secondary);
  }
  .entry-body :global(p) { line-height: 1.75; }
</style>
