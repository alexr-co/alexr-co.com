---
import Base from '../layouts/Base.astro';
import { site } from '../site.config';
---

<Base title="Resume" description={site.meta.resume}>
  <p class="prompt-line"><span class="prompt">$</span> cat resume.txt</p>
  <h1>Resume</h1>
  <p class="lede">
    A condensed work history. The full PDF lives
    <a href={site.resumeFile}>here</a>.
  </p>

  <section class="block">
    <h2>Experience</h2>

    <article class="entry">
      <header class="entry-head">
        <h3>ADC Engineer II &middot; <span class="company">Amazon Web Services</span></h3>
        <span class="dates">2022 &mdash; present</span>
      </header>
      <ul class="bullets">
        <li>Support and troubleshoot core VPC networking services across 6 isolated regions spanning 3 air-gapped partitions; contributed to the launch buildout for 3 of those regions by sequencing interdependent components through CI/CD pipelines.</li>
        <li>Designed and built an internal backup service end-to-end in CDK, protecting hosts across multiple regions and cutting recovery time from 1+ hours to under 10 seconds, with full CloudWatch monitoring across all components.</li>
        <li>Operate 100+ CI/CD pipelines and adapt Python and Java Lambda functions to resolve partition-specific compatibility issues, from SSL/TLS certificate chains to environment-specific config generation.</li>
        <li>Handle high-severity, after-hours on-call incidents with live log and metric analysis to drive root cause; mentor and onboard peers on a team of ~10 engineers.</li>
      </ul>
    </article>

    <article class="entry">
      <header class="entry-head">
        <h3>IT Support Specialist &middot; <span class="company">NCI Information Systems</span></h3>
        <span class="dates">2020 &mdash; 2022</span>
      </header>
      <ul class="bullets">
        <li>Provided expedited IT support to senior Department of Defense officials under rapid-turnaround SLAs, closing 100+ tickets per month as top resolver.</li>
        <li>Developed PowerShell and Batch automation that cut certain task time by 75% and eliminated 1+ hours of after-hours support.</li>
      </ul>
    </article>

    <article class="entry">
      <header class="entry-head">
        <h3>IT Specialist &middot; <span class="company">US Army Reserve</span></h3>
        <span class="dates">2018 &mdash; 2022</span>
      </header>
      <ul class="bullets">
        <li>Administered LAN/WAN and full network stacks on Cisco routing and switching hardware, maintaining 99% uptime.</li>
        <li>Established field connectivity during annual training exercises, keeping 3 Army companies linked to remote sites for mission operations.</li>
      </ul>
    </article>

    <article class="entry">
      <header class="entry-head">
        <h3>Deployment Team Lead &middot; <span class="company">22nd Century Technologies</span></h3>
        <span class="dates">2019 &mdash; 2020</span>
      </header>
      <ul class="bullets">
        <li>Led a team of 5 to prepare, deploy, and maintain end-user devices; set service policies that drove consistent ticket resolution.</li>
        <li>Maintained an audit-quality asset database; imaged hundreds of new devices and sanitized end-of-life hardware.</li>
      </ul>
    </article>
  </section>

  <section class="block">
    <h2>Education</h2>
    <article class="entry">
      <header class="entry-head">
        <h3>A.S. Computer Science &middot; <span class="company">Northern Virginia Community College</span></h3>
        <span class="dates">2020</span>
      </header>
    </article>
  </section>

  <section class="block">
    <h2>Skills</h2>
    <p class="skill-row"><span class="skill-key">languages</span> <code>python</code> <code>java</code> <code>typescript</code> <code>powershell</code></p>
    <p class="skill-row"><span class="skill-key">cloud &amp; infra</span> <code>aws</code> <code>cdk</code> <code>cloudwatch</code> <code>docker</code> <code>ci/cd</code></p>
    <p class="skill-row"><span class="skill-key">frontend</span> <code>react</code> <code>astro</code></p>
  </section>
</Base>

<style>
  .prompt-line {
    color: var(--text-muted);
    font-size: 0.8rem;
    margin: 0 0 0.5rem;
  }
  h1 { margin: 0 0 1.25rem; }
  .lede { max-width: 60ch; }

  .block { margin-bottom: 2.5rem; }
  .block h2 { margin: 0 0 1.25rem; padding-bottom: 0.4rem; border-bottom: 1px solid var(--border-muted); }

  .entry { margin-bottom: 1.5rem; }

  .entry-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.5rem;
  }

  .entry-head h3 { margin: 0; font-size: 1rem; }
  .company { color: var(--accent-link); font-weight: 400; }
  .dates { color: var(--text-faint); font-size: 0.8rem; white-space: nowrap; }

  .bullets {
    margin: 0.25rem 0 0;
    padding-left: 1.25rem;
    color: var(--text-secondary);
  }
  .bullets li { margin-bottom: 0.25rem; }

  .skill-row {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin: 0.5rem 0;
  }

  .skill-key {
    color: var(--text-muted);
    min-width: 6rem;
  }
</style>
